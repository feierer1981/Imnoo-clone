rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktion: Rolle des Nutzers aus users/{uid} lesen
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rolle;
    }

    function isUser() {
      return request.auth != null && getUserRole() == 'user';
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    // users/{uid} - Nutzer darf eigenes Profil lesen, Admin darf alle lesen und Rollen aendern
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      // Erstellen bei Registrierung erlaubt (rolle muss "none" sein)
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.rolle == 'none';
      // Admin darf Rollen aendern
      allow update: if isAdmin();
      allow delete: if false;

      // users/{uid}/bauteile - nur freigeschaltete Nutzer (eigene) oder Admin (alle)
      match /bauteile/{bauteilId} {
        allow read: if (request.auth != null && request.auth.uid == userId && isUser()) || isAdmin();
        allow create: if (request.auth != null && request.auth.uid == userId && isUser()) || isAdmin();
        allow update, delete: if (request.auth != null && request.auth.uid == userId && isUser()) || isAdmin();
      }

      // users/{uid}/profil - Kontaktdaten des Nutzers
      match /profil/{docId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId && isUser()) || isAdmin();
      }

      // users/{uid}/workflows - Kalkulations-Workflows des Nutzers
      match /workflows/{workflowId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId && isUser()) || isAdmin();
      }
    }

    // Kalkulationen - nur freigeschaltete Nutzer, eigene Daten
    match /kalkulationen/{docId} {
      allow read, write: if isUser() || isAdmin();
    }

    // Angebote - nur freigeschaltete Nutzer
    match /angebote/{docId} {
      allow read, write: if isUser() || isAdmin();
    }

    // Materialpreise - lesen fuer alle freigeschalteten Nutzer
    match /materialpreise/{docId} {
      allow read: if isUser() || isAdmin();
      allow write: if isAdmin();
    }

    // Prompts - nur Admin (Erstellung, Bearbeitung, Loeschung)
    match /prompts/{promptId} {
      allow read, write: if isAdmin();
    }
  }
}
