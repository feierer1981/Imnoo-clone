rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Bauteile-Dateien: Nutzer darf nur in seinem eigenen Bereich lesen/schreiben.
    // Rollenprüfung (rolle == "user") erfolgt auf Firestore-Ebene beim Speichern
    // des Bauteil-Dokuments unter users/{uid}/bauteile.
    match /bauteile/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Hochladen: max. 50 MB
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 50 * 1024 * 1024;
      // Löschen: beim Ersetzen oder Entfernen von Bauteilen
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Profil-Dateien (Firmenlogo): Nutzer darf nur sein eigenes Logo lesen/schreiben.
    match /profile/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Hochladen: max. 5 MB
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
