rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Bauteile-Dateien: Nutzer darf nur in seinem eigenen Bereich lesen/schreiben.
    // Rollenprüfung (rolle == "user") erfolgt auf Firestore-Ebene beim Speichern
    // des Bauteil-Dokuments unter users/{uid}/bauteile.
    match /bauteile/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
