rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Bauteile-Dateien: nur freigeschaltete Nutzer in eigenem Bereich
    match /bauteile/{userId}/{allPaths=**} {
      // Lesen: nur eigener Bereich, authentifiziert + rolle "user"
      allow read: if request.auth != null && request.auth.uid == userId
                  && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rolle == 'user';

      // Schreiben: nur eigener Bereich, authentifiziert + rolle "user", max 50 MB
      allow write: if request.auth != null && request.auth.uid == userId
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rolle == 'user'
                   && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
